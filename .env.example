# ─── AMILCAR Auto Care — Environment Configuration ───
# Copy this file to .env and fill in values:
#   cp .env.example .env

# Flask
FLASK_ENV=development          # development | production
SECRET_KEY=                    # Leave empty to auto-generate; set in production

# Server
PORT=5000
HOST=0.0.0.0

# CORS (comma-separated origins, or leave empty for same-origin only)
CORS_ORIGINS=                  # e.g. https://amilcar.tn,https://admin.amilcar.tn

# WhatsApp (CallMeBot)
WA_CALLMEBOT_PHONE=
WA_CALLMEBOT_APIKEY=

# Telegram Backup
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# VAPID Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=
